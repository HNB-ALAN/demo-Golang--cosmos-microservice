# USC Platform Shared Library - Git Ignore

# Environment files (contain secrets)
.env
.env.local
.env.production
.env.staging
*.env

# Logs
*.log
logs/
log/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
vendor/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# next.js build output
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Go specific
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Build artifacts
build/
dist/
bin/

# Test artifacts
test-results/
coverage.out

# SSL certificates (development)
*.pem
*.crt
*.key
*.p12
*.pfx

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup
*.old

# Archive files
*.zip
*.tar.gz
*.rar
*.7z

# Configuration files with secrets
config.local.yaml
config.production.yaml
config.staging.yaml
secrets.yaml
credentials.yaml

# Kubernetes secrets
k8s-secrets.yaml
k8s-credentials.yaml

# Docker files
.dockerignore
docker-compose.override.yml

# Terraform files
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Helm files
charts/*.tgz

# Local development files
local/
dev/
development/

# Production files
prod/
production/

# Staging files
staging/
