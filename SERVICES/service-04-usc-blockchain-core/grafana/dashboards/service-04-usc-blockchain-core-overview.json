{
  "title": "USC Blockchain Overview",
  "tags": ["service-04-usc-blockchain-core", "usc-platform"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (QPS)",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(blockchain_requests_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        {"format": "reqps", "label": "Requests/sec"},
        {"format": "short"}
      ],
      "xaxis": {"mode": "time", "show": true}
    },
    {
      "id": 2,
      "title": "Latency (p50, p95, p99)",
      "type": "graph",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(blockchain_request_duration_seconds_bucket[5m])) by (le, method))",
          "legendFormat": "p50 {{method}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(blockchain_request_duration_seconds_bucket[5m])) by (le, method))",
          "legendFormat": "p95 {{method}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(blockchain_request_duration_seconds_bucket[5m])) by (le, method))",
          "legendFormat": "p99 {{method}}",
          "refId": "C"
        }
      ],
      "yaxes": [
        {"format": "s", "label": "Latency"},
        {"format": "short"}
      ],
      "xaxis": {"mode": "time", "show": true}
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "graph",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(blockchain_errors_total[5m])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        {"format": "ops", "label": "Errors/sec"},
        {"format": "short"}
      ],
      "xaxis": {"mode": "time", "show": true}
    },
    {
      "id": 4,
      "title": "Service Health",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "up{job=\"service-04-usc-blockchain-core\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "Down", "color": "red"},
                "1": {"text": "Up", "color": "green"}
              }
            }
          ]
        }
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": []
  }
}

