# Environment Variables for USC Social Platform
# Copy this file to .env and fill in your actual values

# Database
POSTGRES_PASSWORD=your_postgres_password

# Redis
REDIS_PASSWORD=your_redis_password

# InfluxDB
INFLUX_TOKEN=your_influxdb_token_here
INFLUX_ADMIN_TOKEN=your_influxdb_admin_token_here

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_SECRET_BLOCKCHAIN=your_blockchain_jwt_secret_key_min_32_chars

# AWS SES Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
AWS_SES_FROM_EMAIL=your_email@domain.com
AWS_SES_FROM_NAME=USC-Notification-Service

# BigQuery
BIGQUERY_PROJECT_ID=your_bigquery_project_id
BIGQUERY_DATASET=analytics_data